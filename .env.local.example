# ─── OpenAI (powers the on-site protocol guide) ─────────────
OPENAI_API_KEY=sk-...

# ─── Stripe (powers checkout) ──────────────────────────────
# Use TEST mode keys from https://dashboard.stripe.com/test/apikeys
# Test card: 4242 4242 4242 4242, any future date, any CVC, any ZIP.
STRIPE_SECRET_KEY=sk_test_...

# Optional — overrides the success/cancel URL origin Stripe redirects to.
# Leave unset locally (defaults to the request origin).
# NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# ─── Supabase (powers /login, /signup, /track) ─────────────
# Project Settings → API in your Supabase dashboard.
# After pasting keys, run `supabase/schema.sql` once in the SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
